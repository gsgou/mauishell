<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sample="clr-namespace:Sample"
             x:DataType="sample:TwoViewModel"
             x:Class="Sample.TwoPage"
             Title="Two">
    <VerticalStackLayout
        Padding="30,0"
        Spacing="25">
        <Label Text="{Binding Text, StringFormat='Text: {0}'}" FontSize="24" />

        <Label Text="--- Builder Navigation ---" FontAttributes="Bold" />

        <Button Text="Pop 2, Push 1"
                Command="{Binding PopAndPushCommand}" />

        <Button Text="Go Back"
                Command="{Binding GoBackCommand}" />
    </VerticalStackLayout>
</ContentPage>
