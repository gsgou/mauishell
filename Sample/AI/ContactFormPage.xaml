<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ai="clr-namespace:Sample.AI"
             x:Class="Sample.AI.ContactFormPage"
             x:DataType="ai:ContactFormViewModel"
             Title="Contact Us">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Contact Form" FontAttributes="Bold" FontSize="22" />

            <Label Text="Name" FontAttributes="Bold" />
            <Entry Text="{Binding Name}" Placeholder="Full name" />

            <Label Text="Email" FontAttributes="Bold" />
            <Entry Text="{Binding Email}" Placeholder="you@example.com" Keyboard="Email" />

            <Label Text="Phone" FontAttributes="Bold" />
            <Entry Text="{Binding Phone}" Placeholder="(optional)" Keyboard="Telephone" />

            <Label Text="Subject" FontAttributes="Bold" />
            <Entry Text="{Binding Subject}" Placeholder="What would you like to discuss?" />

            <Label Text="Message" FontAttributes="Bold" />
            <Editor Text="{Binding Message}" HeightRequest="120" Placeholder="Additional details..." />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Button Text="Send" Command="{Binding SubmitCommand}" />
            <Label Text="Message sent!" TextColor="Green" FontAttributes="Bold"
                   IsVisible="{Binding IsSubmitted}" />

            <Button Text="Go Back" Command="{Binding GoBackCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
