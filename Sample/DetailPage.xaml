<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sample="clr-namespace:Sample"
             x:DataType="sample:DetailViewModel"
             x:Class="Sample.DetailPage"
             Title="Detail">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Received Parameters"
                   FontAttributes="Bold" FontSize="16" />
            <Label Text="{Binding Text, StringFormat='Text: {0}'}" />
            <Label Text="{Binding Source, StringFormat='Source: {0}'}" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="Navigation" FontAttributes="Bold" FontSize="16" />

            <Button Text="Go Back"
                    Command="{Binding GoBackCommand}" />

            <Button Text="Go Back with Arg"
                    Command="{Binding GoBackWithArgCommand}" />

            <Button Text="Pop to Root"
                    Command="{Binding PopToRootCommand}" />

            <Button Text="Push Another Detail"
                    Command="{Binding PushAnotherCommand}" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="Navigation Confirmation"
                   FontAttributes="Bold" FontSize="16" />
            <Label Text="Toggle to require confirmation before leaving this page." />
            <HorizontalStackLayout Spacing="10">
                <Switch IsToggled="{Binding RequireConfirmation}" />
                <Label Text="{Binding RequireConfirmation, StringFormat='Enabled: {0}'}"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
