<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sample="clr-namespace:Sample"
             x:DataType="sample:ModalDemoViewModel"
             x:Class="Sample.ModalDemoPage"
             Shell.PresentationMode="Modal"
             Title="Modal Demo">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="This page was presented modally."
                   TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />

            <Label Text="Received Args" FontAttributes="Bold" FontSize="16" />
            <Label Text="{Binding Title, StringFormat='Title: {0}'}" />
            <Label Text="{Binding OptionalNote, StringFormat='Note: {0}'}" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Button Text="Push Detail Within Modal"
                    Command="{Binding PushWithinModalCommand}" />

            <Button Text="Close Modal"
                    Command="{Binding CloseCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
