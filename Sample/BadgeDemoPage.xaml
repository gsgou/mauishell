<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sample="clr-namespace:Sample"
             x:DataType="sample:BadgeDemoViewModel"
             x:Class="Sample.BadgeDemoPage"
             Title="Tab Badges">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Tab badges appear on the tab bar. Switch to the Tabbed Shell from Shell Switching to see them on the Badges tab."
                   TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />

            <Label Text="Set Badge Value" FontAttributes="Bold" FontSize="16" Padding="0,10,0,0" />

            <Button Text="Set Badge = 1"
                    Command="{Binding SetBadgeCommand}"
                    CommandParameter="1" />

            <Button Text="Set Badge = 5"
                    Command="{Binding SetBadgeCommand}"
                    CommandParameter="5" />

            <Button Text="Set Badge = 99"
                    Command="{Binding SetBadgeCommand}"
                    CommandParameter="99" />

            <Button Text="Clear Badge"
                    Command="{Binding ClearBadgeCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
